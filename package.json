{
  "name": "tripwire",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "postinstall": "node scripts/fix-nitro-windows-paths.mjs",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint . && pnpm --filter @tripwire/web lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preflight": "pnpm typecheck && pnpm lint && pnpm format:check",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "pnpm --filter @tripwire/web db:generate",
    "db:migrate": "pnpm --filter @tripwire/web db:migrate",
    "db:push": "pnpm --filter @tripwire/web db:push",
    "db:pull": "pnpm --filter @tripwire/web db:pull",
    "db:studio": "pnpm --filter @tripwire/web db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.5.10",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
