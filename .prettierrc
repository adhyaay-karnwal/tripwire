{
  "endOfLine": "lf",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindStylesheet": "apps/web/src/styles.css",
  "importOrder": ["^components/(.*)$", "^[./]"],
  "tailwindFunctions": ["cn", "cva"],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
